<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Checkbox для отправки -->
    <CheckBox
        android:id="@+id/senderCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Sender" />

    <!-- Spinner для выбора режима -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="Mode:" />

    <Spinner
        android:id="@+id/testModeSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <!-- Кнопка сброса статистики -->
    <Button
        android:id="@+id/resetStatsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Reset Statistics (All Devices)" />

    <!-- Заголовок для списка устройств -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Connected Devices Info:"
        android:textStyle="bold" />

    <!-- ScrollView для списка информации по устройствам -->
    <ScrollView
        android:id="@+id/devicesInfoScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F9F9F9"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/devicesInfoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/devicesInfoPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No devices connected yet..."
                android:textColor="#888888"
                android:textSize="12sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>