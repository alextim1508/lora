<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Status Indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <ImageView
                android:id="@+id/statusIndicator"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/status_indicator_background"
                app:srcCompat="@drawable/ic_status_light" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Ready"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- CMD_GET_VERSION -->
        <Button
            android:id="@+id/sendGetVersionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Get Version" />

        <!-- Version Display -->
        <TextView
            android:id="@+id/versionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Version: --"
            android:textSize="14sp" />



        <!-- CMD_GET_CONFIGURATION -->
        <Button
            android:id="@+id/sendGetConfigButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Get Config" />

        <!-- CMD_SET_CONFIGURATION -->
        <Button
            android:id="@+id/sendSetConfigButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Set Config" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="LoRa Type"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/loraTypeSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="LoRa Power"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/loraPowerIndexSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="LoRa Rate"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/loraRateIndexSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="LoRa Channel"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/loraChannelIndexSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <!-- Voltage and Temperature Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Device Status"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/voltageLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Voltage: -- V"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/temperatureLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Temperature: -- °C"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Response Code Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Response Code"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/responseCodeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:text="Code: --"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- CMD_RESTART -->
        <Button
            android:id="@+id/sendRestartButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Restart" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>